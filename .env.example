# PostgreSQL Local Database Configuration
# Copy this file to .env and adjust values if necessary for local development.
# DO NOT place production credentials or Supabase URLs in this file.

POSTGRES_DB=velvet_salon
POSTGRES_USER=velvet_user
POSTGRES_PASSWORD=velvet_password
POSTGRES_PORT=5432

# Backend configuration
PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_SEED_ENABLED=false

# Frontend configuration
# Note: For production, configure this in your frontend hosting platform (e.g. Vercel)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
